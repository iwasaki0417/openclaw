{
  "version": 1,
  "jobs": [
    {
      "id": "daily-news",
      "name": "OpenClaw News",
      "description": "ニュース・決算・ポートフォリオ診断の統合レポート配信",
      "schedule": "30 7 * * 1-5",
      "timezone": "Asia/Tokyo",
      "payload": {
        "agent": "main",
        "message": "DAILY-NEWS.md を参照し、OpenClaw News を作成してメール送信",
        "kind": "agentTurn",
        "model": "anthropic/claude-opus-4-6"
      },
      "state": {},
      "enabled": true,
      "delivery": {
        "mode": "announce"
      },
      "sessionTarget": "isolated"
    },
    {
      "id": "stock-jp-midday",
      "name": "東証後場チェック",
      "description": "東証後場開始の株価チェック",
      "schedule": "35 12 * * 1-5",
      "timezone": "Asia/Tokyo",
      "payload": {
        "agent": "main",
        "message": "HEARTBEAT実行: 後場開始",
        "kind": "agentTurn"
      },
      "state": {},
      "enabled": true,
      "delivery": {
        "mode": "announce"
      }
    }
  ]
}