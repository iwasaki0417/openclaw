			"label": "APIトークン",
			"sensitive": true
		},
		"webhookSecret": {
			"label": "Webhook署名トークン",
			"sensitive": true
		},
		"webhookPath": {
			"label": "Webhookパス",
			"placeholder": "/chatwork/webhook"
